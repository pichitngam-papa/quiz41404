<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>แบบทดสอบ กฎหมายแรงงาน 41404</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #1d4ed8; --blue-light: #eff6ff; --blue-border: #93c5fd;
  --green: #16a34a; --green-light: #f0fdf4; --green-border: #86efac;
  --red: #dc2626; --red-light: #fef2f2; --red-border: #fca5a5;
  --orange: #ea580c; --orange-light: #fff7ed;
  --gray: #374151; --bg: #f1f5f9;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Sarabun', sans-serif; background: var(--bg); color: var(--gray); font-size: 16px; line-height: 1.7; }

/* ===== MENU ===== */
#menu-screen { min-height: 100vh; padding: 0 0 60px; }
.hero {
  background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
  color: white; padding: 44px 20px 36px; text-align: center;
}
.hero h1 { font-size: 2rem; font-weight: 800; margin-bottom: 6px; }
.hero p { opacity: .85; font-size: 1rem; }
.unit-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 14px; max-width: 860px; margin: 36px auto 0; padding: 0 20px;
}
.unit-btn {
  background: white; border: 2px solid #e5e7eb; border-radius: 14px;
  padding: 18px 14px; cursor: pointer; text-align: left;
  transition: all .15s; font-family: 'Sarabun', sans-serif;
}
.unit-btn:hover { border-color: var(--blue); box-shadow: 0 4px 16px rgba(29,78,216,.15); transform: translateY(-2px); }
.unit-btn.done { border-color: var(--green); background: var(--green-light); }
.unit-btn.perfect { border-color: #f59e0b; background: #fffbeb; }
.unit-num { font-size: 0.78rem; font-weight: 700; color: var(--blue); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .05em; }
.unit-title { font-size: 0.88rem; font-weight: 700; color: #111; line-height: 1.4; margin-bottom: 8px; }
.unit-score { font-size: 0.78rem; color: #6b7280; }
.score-bar-wrap { background: #e5e7eb; border-radius: 99px; height: 5px; margin-top: 6px; }
.score-bar { height: 5px; border-radius: 99px; background: var(--blue); transition: width .4s; }
.all-btn {
  display: block; margin: 28px auto 0; max-width: 300px;
  background: linear-gradient(135deg, #1e3a8a, #7c3aed);
  color: white; border: none; border-radius: 14px;
  padding: 16px 32px; font-size: 1.05rem; font-weight: 800;
  cursor: pointer; font-family: 'Sarabun', sans-serif;
  box-shadow: 0 4px 16px rgba(29,78,216,.25);
}
.all-btn:hover { opacity: .9; }

/* ===== QUIZ ===== */
#quiz-screen { display: none; min-height: 100vh; }
.quiz-header {
  background: white; border-bottom: 2px solid #e5e7eb;
  padding: 14px 20px; display: flex; align-items: center;
  gap: 14px; position: sticky; top: 0; z-index: 10;
}
.back-btn {
  background: var(--blue-light); border: 1px solid var(--blue-border);
  color: var(--blue); border-radius: 8px; padding: 6px 14px;
  cursor: pointer; font-family: 'Sarabun', sans-serif; font-size: 0.9rem; font-weight: 700;
}
.back-btn:hover { background: var(--blue); color: white; }
.quiz-title { font-weight: 800; font-size: 1rem; flex: 1; }
.progress-wrap { display: flex; align-items: center; gap: 8px; }
.progress-text { font-size: 0.85rem; font-weight: 700; color: var(--blue); }
.progress-bar-outer { width: 100px; height: 8px; background: #e5e7eb; border-radius: 99px; }
.progress-bar-inner { height: 8px; background: var(--blue); border-radius: 99px; transition: width .3s; }

.quiz-body { max-width: 720px; margin: 0 auto; padding: 32px 20px 80px; }
.q-card {
  background: white; border-radius: 20px; padding: 30px 28px;
  box-shadow: 0 4px 24px rgba(0,0,0,.07); margin-bottom: 24px;
}
.q-meta {
  display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
}
.q-badge {
  background: var(--blue); color: white; border-radius: 8px;
  padding: 3px 12px; font-size: 0.82rem; font-weight: 800;
}
.q-unit-tag {
  background: var(--blue-light); color: var(--blue); border-radius: 8px;
  padding: 3px 10px; font-size: 0.82rem; font-weight: 700;
}
.q-text { font-size: 1.05rem; font-weight: 700; color: #111; line-height: 1.65; margin-bottom: 22px; }

/* Options */
.options { display: flex; flex-direction: column; gap: 10px; }
.opt-btn {
  display: flex; align-items: flex-start; gap: 12px;
  border: 2px solid #e5e7eb; border-radius: 12px; padding: 13px 16px;
  cursor: pointer; background: white; text-align: left;
  font-family: 'Sarabun', sans-serif; font-size: 0.95rem;
  transition: all .12s; width: 100%;
}
.opt-btn:not(.answered):hover { border-color: var(--blue); background: var(--blue-light); }
.opt-letter {
  min-width: 28px; height: 28px; border-radius: 50%;
  background: #f3f4f6; display: flex; align-items: center;
  justify-content: center; font-weight: 800; font-size: 0.82rem; color: #374151;
  flex-shrink: 0;
}
.opt-text { flex: 1; line-height: 1.55; font-weight: 600; }

/* States */
.opt-btn.correct { border-color: var(--green); background: var(--green-light); }
.opt-btn.correct .opt-letter { background: var(--green); color: white; }
.opt-btn.wrong { border-color: var(--red); background: var(--red-light); }
.opt-btn.wrong .opt-letter { background: var(--red); color: white; }
.opt-btn.missed { border-color: var(--green); background: var(--green-light); opacity: .7; }
.opt-btn.missed .opt-letter { background: var(--green); color: white; }
.opt-btn.answered { cursor: default; }

/* Explanation */
.explanation {
  margin-top: 16px; padding: 14px 16px;
  border-radius: 12px; font-size: 0.9rem; line-height: 1.65;
  display: none;
}
.explanation.correct-exp { background: var(--green-light); border: 1px solid var(--green-border); color: #14532d; }
.explanation.wrong-exp { background: var(--red-light); border: 1px solid var(--red-border); color: #7f1d1d; }
.exp-label { font-weight: 800; margin-bottom: 4px; }

/* Nav buttons */
.nav-row { display: flex; justify-content: flex-end; margin-top: 20px; }
.nav-btn {
  background: var(--blue); color: white; border: none; border-radius: 12px;
  padding: 12px 28px; font-size: 0.95rem; font-weight: 800; cursor: pointer;
  font-family: 'Sarabun', sans-serif; display: none;
}
.nav-btn:hover { background: #1e40af; }

/* ===== RESULT ===== */
#result-screen { display: none; min-height: 100vh; }
.result-hero {
  padding: 48px 20px 36px; text-align: center;
  background: linear-gradient(135deg, #1e3a8a, #7c3aed); color: white;
}
.result-score-big { font-size: 4rem; font-weight: 800; }
.result-label { font-size: 1.1rem; opacity: .9; margin-bottom: 16px; }
.result-msg { font-size: 1.25rem; font-weight: 700; }
.result-body { max-width: 660px; margin: 0 auto; padding: 32px 20px; }
.review-list { list-style: none; }
.review-item {
  background: white; border-radius: 14px; padding: 16px 18px;
  margin-bottom: 12px; border-left: 5px solid #e5e7eb;
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.review-item.correct-item { border-left-color: var(--green); }
.review-item.wrong-item { border-left-color: var(--red); }
.review-q { font-weight: 700; font-size: 0.92rem; color: #111; margin-bottom: 6px; }
.review-ans { font-size: 0.87rem; }
.review-ans .correct-ans { color: var(--green); font-weight: 700; }
.review-ans .wrong-ans { color: var(--red); font-weight: 700; }
.result-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 28px; }
.res-btn {
  padding: 13px 28px; border-radius: 12px; font-size: 0.95rem; font-weight: 800;
  cursor: pointer; font-family: 'Sarabun', sans-serif; border: none;
}
.res-btn.primary { background: var(--blue); color: white; }
.res-btn.secondary { background: white; border: 2px solid #e5e7eb; color: var(--gray); }
.res-btn:hover { opacity: .85; }

@media(max-width: 600px) {
  .unit-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .hero h1 { font-size: 1.5rem; }
  .quiz-header { flex-wrap: wrap; }
  .progress-wrap { order: 3; width: 100%; }
  .progress-bar-outer { flex: 1; }
  .q-card { padding: 22px 18px; }
}
</style>
</head>
<body>

<!-- ===== MENU ===== -->
<div id="menu-screen">
  <div class="hero">
    <h1>📝 แบบทดสอบกฎหมายแรงงาน 41404</h1>
    <p>หน่วยละ 4 ข้อ • เฉลยทันทีพร้อมคำอธิบาย</p>
  </div>
  <div class="unit-grid" id="unit-grid"></div>
  <button class="all-btn" onclick="startQuiz('all')">🎯 ทดสอบรวมทุกหน่วย (60 ข้อ)</button>
</div>

<!-- ===== QUIZ ===== -->
<div id="quiz-screen">
  <div class="quiz-header">
    <button class="back-btn" onclick="goBack()">← กลับ</button>
    <div class="quiz-title" id="quiz-title-label">แบบทดสอบ</div>
    <div class="progress-wrap">
      <span class="progress-text" id="progress-text">1 / 4</span>
      <div class="progress-bar-outer"><div class="progress-bar-inner" id="progress-bar" style="width:0%"></div></div>
    </div>
  </div>
  <div class="quiz-body">
    <div class="q-card" id="q-card">
      <div class="q-meta">
        <span class="q-badge" id="q-badge">ข้อ 1</span>
        <span class="q-unit-tag" id="q-unit-tag">หน่วยที่ 1</span>
      </div>
      <div class="q-text" id="q-text"></div>
      <div class="options" id="options"></div>
      <div class="explanation" id="explanation"></div>
    </div>
    <div class="nav-row">
      <button class="nav-btn" id="next-btn" onclick="nextQuestion()">ถัดไป →</button>
    </div>
  </div>
</div>

<!-- ===== RESULT ===== -->
<div id="result-screen">
  <div class="result-hero">
    <div class="result-score-big" id="result-score-big">0/0</div>
    <div class="result-label" id="result-label">คะแนน</div>
    <div class="result-msg" id="result-msg"></div>
  </div>
  <div class="result-body">
    <div class="result-actions">
      <button class="res-btn primary" id="retry-btn" onclick="retryQuiz()">🔄 ทำใหม่</button>
      <button class="res-btn secondary" onclick="goMenu()">← เลือกหน่วย</button>
    </div>
    <br>
    <ul class="review-list" id="review-list"></ul>
  </div>
</div>

<script>
const UNITS = [
  { id:1,  title:"หลักการกฎหมายแรงงานและสัญญาจ้าง" },
  { id:2,  title:"การคุ้มครองแรงงาน" },
  { id:3,  title:"ค่าตอบแทนในการทำงาน" },
  { id:4,  title:"สวัสดิการและความปลอดภัยในการทำงาน" },
  { id:5,  title:"การเลิกจ้างและค่าชดเชย" },
  { id:6,  title:"กฎหมายเงินทดแทน" },
  { id:7,  title:"กฎหมายประกันสังคม" },
  { id:8,  title:"องค์กรแรงงาน" },
  { id:9,  title:"ข้อตกลงเกี่ยวกับสภาพการจ้าง" },
  { id:10, title:"การระงับข้อพิพาทแรงงาน" },
  { id:11, title:"การนัดหยุดงานและปิดงาน" },
  { id:12, title:"การกระทำอันไม่เป็นธรรม" },
  { id:13, title:"แรงงานพิเศษ" },
  { id:14, title:"ศาลแรงงาน" },
  { id:15, title:"วิธีพิจารณาคดีแรงงาน" },
];

const ALL_Q = [
// ===== หน่วย 1 =====
{ ch:1, q:"กฎหมายแรงงานจัดอยู่ในประเภทกฎหมายใด?",
  opts:["กฎหมายมหาชน","กฎหมายเอกชน","กฎหมายสังคม","กฎหมายระหว่างประเทศ"],
  ans:2, exp:"กฎหมายแรงงานเป็น 'กฎหมายสังคม' (Social Law) ที่มุ่งคุ้มครองฝ่ายที่มีอำนาจต่อรองน้อยกว่าคือลูกจ้าง ไม่ใช่กฎหมายมหาชนหรือกฎหมายเอกชนล้วนๆ" },
{ ch:1, q:"ตาม ป.พ.พ. มาตรา 575 ลักษณะสำคัญที่สุดที่ทำให้สัญญาจ้างแรงงานแตกต่างจากสัญญาจ้างทำของคืออะไร?",
  opts:["ต้องทำเป็นหนังสือเสมอ","มีความสัมพันธ์แบบบังคับบัญชา","ต้องกำหนดค่าจ้างชัดเจน","มีกำหนดระยะเวลาสิ้นสุด"],
  ans:1, exp:"สัญญาจ้างแรงงานมีลักษณะสำคัญคือ 'ความสัมพันธ์แบบบังคับบัญชา' (Subordination) ลูกจ้างต้องทำงานตามคำสั่งนายจ้าง ซึ่งต่างจากสัญญาจ้างทำของที่ผู้รับจ้างมีอิสระในการทำงาน" },
{ ch:1, q:"สัญญาจ้างแรงงานสามารถทำได้โดยวิธีใด?",
  opts:["ต้องทำเป็นหนังสือเท่านั้น","ต้องมีพยานอย่างน้อย 2 คน","ทำด้วยวาจาหรือหนังสือก็ได้","ต้องจดทะเบียนกับกรมแรงงาน"],
  ans:2, exp:"สัญญาจ้างแรงงานไม่ต้องทำเป็นหนังสือ ทำด้วยวาจาหรือเป็นหนังสือก็มีผลสมบูรณ์ตามกฎหมาย แต่ควรทำเป็นหนังสือเพื่อหลักฐาน" },
{ ch:1, q:"พ.ร.บ.คุ้มครองแรงงาน พ.ศ.2541 มีทั้งหมดกี่มาตรา กี่หมวด?",
  opts:["120 มาตรา 12 หมวด","166 มาตรา 16 หมวด","180 มาตรา 18 หมวด","200 มาตรา 20 หมวด"],
  ans:1, exp:"พ.ร.บ.คุ้มครองแรงงาน พ.ศ.2541 มี 166 มาตรา จัดเป็น 16 หมวด เป็นกฎหมายหลักในการคุ้มครองแรงงานไทย" },

// ===== หน่วย 2 =====
{ ch:2, q:"ลูกจ้างลาคลอดบุตรครรภ์หนึ่งมีสิทธิลาได้กี่วัน และได้รับค่าจ้างกี่วัน?",
  opts:["ลาได้ 90 วัน ได้ค่าจ้าง 45 วัน","ลาได้ 98 วัน ได้ค่าจ้าง 45 วัน","ลาได้ 98 วัน ได้ค่าจ้าง 60 วัน","ลาได้ 120 วัน ได้ค่าจ้าง 60 วัน"],
  ans:1, exp:"ตามมาตรา 41 ลาคลอดได้ไม่เกิน 98 วัน/ครรภ์ (รวมวันหยุด) แต่นายจ้างจ่ายค่าจ้างในวันลาคลอดไม่เกิน 45 วัน ส่วนที่เหลือสามารถรับจากประกันสังคมได้" },
{ ch:2, q:"ลูกจ้างที่ป่วยจริงมีสิทธิลาป่วยได้นานเท่าใด และได้รับค่าจ้างกี่วัน?",
  opts:["ลาได้ 30 วัน/ปี ได้ค่าจ้างทั้งหมด","ลาได้ไม่จำกัด ได้ค่าจ้าง 30 วัน/ปี","ลาได้ 60 วัน/ปี ได้ค่าจ้าง 30 วัน/ปี","ลาได้ 45 วัน/ปี ได้ค่าจ้าง 45 วัน/ปี"],
  ans:1, exp:"สิทธิลาป่วยไม่มีกำหนดสูงสุด — ลาได้ตลอดเวลาที่ป่วยจริง แต่นายจ้างจ่ายค่าจ้างระหว่างลาป่วยได้ไม่เกิน 30 วัน/ปี" },
{ ch:2, q:"อายุขั้นต่ำของลูกจ้างตาม พ.ร.บ.คุ้มครองแรงงานคือเท่าไร?",
  opts:["12 ปี","13 ปี","15 ปี","18 ปี"],
  ans:2, exp:"ตามมาตรา 44 ห้ามนายจ้างจ้างลูกจ้างที่มีอายุต่ำกว่า 15 ปี บุคคลอายุต่ำกว่า 18 ปีถือเป็น 'เด็ก' และมีข้อจำกัดพิเศษในการทำงาน" },
{ ch:2, q:"ลูกจ้างที่ลาราชการทหารมีสิทธิลาได้ไม่เกินกี่วัน และได้รับค่าจ้างกี่วัน?",
  opts:["30 วัน ได้ค่าจ้าง 30 วัน","45 วัน ได้ค่าจ้าง 30 วัน","60 วัน ได้ค่าจ้าง 60 วัน","90 วัน ได้ค่าจ้าง 60 วัน"],
  ans:2, exp:"ลาเพื่อรับราชการทหารได้ไม่เกิน 60 วันในปีใดปีหนึ่ง นายจ้างต้องจ่ายค่าจ้างตลอด 60 วันนั้น ตามมาตรา 35" },

// ===== หน่วย 3 =====
{ ch:3, q:"น้ำมันรถที่นายจ้างจ่ายให้ลูกจ้างทุกเดือนในอัตราคงที่ โดยไม่คำนึงว่าได้ใช้จ่ายจริงหรือไม่ ถือเป็น 'ค่าจ้าง' หรือไม่?",
  opts:["ไม่ใช่ค่าจ้าง เป็นค่าสวัสดิการ","ถือเป็นค่าจ้าง เพราะจ่ายโดยไม่ขึ้นอยู่กับการใช้จ่ายจริง","ถือเป็นค่าจ้างเฉพาะเมื่อเกิน 1,000 บาท","ไม่ใช่ค่าจ้าง เป็นเงินค่าตอบแทนพิเศษ"],
  ans:1, exp:"เงินที่นายจ้างจ่ายให้ลูกจ้างเป็นประจำสม่ำเสมอในอัตราคงที่ โดยไม่คำนึงว่าจะมีการใช้จ่ายจริงหรือไม่ ถือว่าเป็น 'ค่าจ้าง' ตามนิยามใน พ.ร.บ.คุ้มครองแรงงาน" },
{ ch:3, q:"คณะกรรมการค่าจ้าง (ไตรภาคี) ไม่คำนึงถึงปัจจัยใดในการกำหนดอัตราค่าจ้างขั้นต่ำ?",
  opts:["ดัชนีค่าครองชีพ","ความสามารถในการจ่ายของธุรกิจ","อัตราแลกเปลี่ยนเงินตราต่างประเทศ","ผลิตภาพแรงงาน"],
  ans:2, exp:"คณะกรรมการค่าจ้างคำนึงถึงดัชนีค่าครองชีพ ผลิตภาพแรงงาน ภาวะเศรษฐกิจ แต่ไม่คำนึงถึง 'อัตราแลกเปลี่ยนเงินตราต่างประเทศ' เพราะค่าจ้างในประเทศไม่ได้ผูกกับเงินตราต่างประเทศโดยตรง" },
