{ ch:14, q:"พ.ร.บ.จัดตั้งศาลแรงงานและวิธีพิจารณาคดีแรงงานมีผลบังคับใช้ตั้งแต่ปี พ.ศ.ใด?",
  opts:["พ.ศ.2512","พ.ศ.2517","พ.ศ.2522","พ.ศ.2526"],
  ans:2, exp:"พ.ร.บ.จัดตั้งศาลแรงงานและวิธีพิจารณาคดีแรงงาน พ.ศ.2522 เป็นกฎหมายที่กำหนดการจัดตั้งและวิธีดำเนินคดีในศาลแรงงาน" },

// ===== หน่วย 15 =====
{ ch:15, q:"อายุความในการฟ้องคดีแรงงานมีกี่ปี?",
  opts:["1 ปี","2 ปี","5 ปี","10 ปี"],
  ans:1, exp:"คดีแรงงานมีอายุความ 2 ปี นับแต่วันที่สิทธิเกิดขึ้น หากปล่อยให้เกิน 2 ปี คดีจะขาดอายุความ ไม่สามารถนำคดีขึ้นฟ้องศาลได้" },
{ ch:15, q:"โจทก์ในคดีแรงงานสามารถยื่นฟ้องคดีในศาลแรงงานที่ใดได้บ้าง?",
  opts:["เฉพาะที่ที่จำเลยมีภูมิลำเนาเท่านั้น","ที่มูลคดีเกิด หรือที่จำเลยมีภูมิลำเนา หรือที่โจทก์มีภูมิลำเนา","เฉพาะที่ที่โจทก์มีภูมิลำเนา","เฉพาะศาลแรงงานกลางในกรุงเทพฯ"],
  ans:1, exp:"โจทก์สามารถเลือกยื่นฟ้องได้ใน 3 ที่ คือ (1) ที่ที่มูลคดีเกิด (2) ที่จำเลยมีภูมิลำเนา หรือ (3) ที่โจทก์มีภูมิลำเนา เพื่อความสะดวกในการดำเนินคดี" },
{ ch:15, q:"ศาลแรงงานมีอำนาจพิเศษที่ศาลทั่วไปไม่มีคืออะไร?",
  opts:["ตัดสินคดีโดยไม่ต้องมีการพิจารณา","สืบพยานและแสวงหาข้อเท็จจริงเองได้โดยไม่ต้องรอคู่ความนำสืบ","ออกคำสั่งให้จำเลยจ่ายเงินก่อนตัดสิน","ห้ามทนายความเข้าร่วมในคดี"],
  ans:1, exp:"ศาลแรงงานมีอำนาจ 'สืบพยานเอง' ได้ (Inquisitorial) ไม่ต้องรอให้คู่ความนำสืบพยาน เพื่อให้ได้ข้อเท็จจริงที่แท้จริงและรวดเร็ว เป็นลักษณะพิเศษของศาลแรงงาน" },
{ ch:15, q:"บริษัทจดทะเบียนเปลี่ยนชื่อและเปลี่ยนสถานะนิติบุคคลใหม่ ลูกจ้างเดิมมีสถานะอย่างไร?",
  opts:["ถือว่าถูกเลิกจ้าง มีสิทธิรับค่าชดเชย","ยังคงเป็นลูกจ้างต่อไป นายจ้างใหม่รับช่วงสิทธิ","ต้องทำสัญญาจ้างใหม่ทุกคน","สัญญาจ้างเดิมสิ้นผล แต่ไม่ได้รับค่าชดเชย"],
  ans:1, exp:"การเปลี่ยนชื่อหรือเปลี่ยนนิติบุคคลของนายจ้างไม่ถือเป็นการเลิกจ้าง ลูกจ้างยังคงมีสถานะเดิม นายจ้างใหม่รับช่วงสิทธิ หน้าที่ และความรับผิดชอบทั้งหมดต่อจากนายจ้างเดิม" },
];

// ===== STATE =====
let currentQuestions = [];
let currentIndex = 0;
let currentUnit = null;
let answers = [];
let scores = {};

function initScores() {
  const saved = localStorage.getItem('quiz41404_scores');
  if (saved) scores = JSON.parse(saved);
}

function saveScores() {
  localStorage.setItem('quiz41404_scores', JSON.stringify(scores));
}

function renderMenu() {
  const grid = document.getElementById('unit-grid');
  grid.innerHTML = '';
  UNITS.forEach(u => {
    const sc = scores['u'+u.id];
    const btn = document.createElement('button');
    btn.className = 'unit-btn' + (sc ? (sc.score === sc.total ? ' perfect' : ' done') : '');
    let scoreHtml = sc
      ? `<div class="unit-score">ทำแล้ว ${sc.score}/${sc.total} ข้อ</div>
         <div class="score-bar-wrap"><div class="score-bar" style="width:${Math.round(sc.score/sc.total*100)}%;background:${sc.score===sc.total?'#f59e0b':sc.score/sc.total>=0.75?'#16a34a':'#1d4ed8'}"></div></div>`
      : `<div class="unit-score">ยังไม่ได้ทำ</div>`;
    btn.innerHTML = `<div class="unit-num">หน่วยที่ ${u.id}</div><div class="unit-title">${u.title}</div>${scoreHtml}`;
    btn.onclick = () => startQuiz('u' + u.id);
    grid.appendChild(btn);
  });
}

function startQuiz(key) {
  currentUnit = key;
  if (key === 'all') {
    currentQuestions = [...ALL_Q].sort(() => Math.random() - .5);
  } else {
    const uid = parseInt(key.replace('u',''));
    currentQuestions = ALL_Q.filter(q => q.ch === uid).sort(() => Math.random() - .5);
  }
  currentIndex = 0;
  answers = new Array(currentQuestions.length).fill(null);
  document.getElementById('menu-screen').style.display = 'none';
  document.getElementById('quiz-screen').style.display = 'block';
  document.getElementById('result-screen').style.display = 'none';
  if (key === 'all') {
    document.getElementById('quiz-title-label').textContent = '🎯 ทดสอบรวมทุกหน่วย';
  } else {
    const uid = parseInt(key.replace('u',''));
    const u = UNITS.find(x => x.id === uid);
    document.getElementById('quiz-title-label').textContent = `หน่วยที่ ${uid}: ${u.title}`;
  }
  renderQuestion();
}

function renderQuestion() {
  const q = currentQuestions[currentIndex];
  const total = currentQuestions.length;
  document.getElementById('q-badge').textContent = `ข้อ ${currentIndex + 1}`;
  document.getElementById('q-unit-tag').textContent = `หน่วยที่ ${q.ch}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('progress-text').textContent = `${currentIndex+1} / ${total}`;
  document.getElementById('progress-bar').style.width = `${Math.round((currentIndex+1)/total*100)}%`;

  const opts = document.getElementById('options');
  opts.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt-btn';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span class="opt-text">${opt}</span>`;
    btn.onclick = () => selectAnswer(i);
    opts.appendChild(btn);
  });

  const exp = document.getElementById('explanation');
  exp.className = 'explanation';
  exp.style.display = 'none';
  exp.innerHTML = '';
  document.getElementById('next-btn').style.display = 'none';

  // If already answered (back navigation not needed here, just ensure clean state)
}

function selectAnswer(chosen) {
  const q = currentQuestions[currentIndex];
  answers[currentIndex] = chosen;
  const isCorrect = chosen === q.ans;

  const optBtns = document.querySelectorAll('.opt-btn');
  optBtns.forEach((btn, i) => {
    btn.classList.add('answered');
    if (i === q.ans) btn.classList.add(chosen === i ? 'correct' : 'missed');
    else if (i === chosen) btn.classList.add('wrong');
  });

  const exp = document.getElementById('explanation');
  exp.className = 'explanation ' + (isCorrect ? 'correct-exp' : 'wrong-exp');
  exp.innerHTML = `<div class="exp-label">${isCorrect ? '✅ ถูกต้อง!' : '❌ ผิด!'}</div>${q.exp}`;
  exp.style.display = 'block';

  const nextBtn = document.getElementById('next-btn');
  nextBtn.style.display = 'block';
  if (currentIndex === currentQuestions.length - 1) {
    nextBtn.textContent = 'ดูผลลัพธ์ →';
  } else {
    nextBtn.textContent = 'ถัดไป →';
  }
}

function nextQuestion() {
  if (currentIndex < currentQuestions.length - 1) {
    currentIndex++;
    renderQuestion();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } else {
    showResult();
  }
}

function showResult() {
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'block';

  const correct = answers.filter((a, i) => a === currentQuestions[i].ans).length;
  const total = currentQuestions.length;
  const pct = Math.round(correct / total * 100);

  document.getElementById('result-score-big').textContent = `${correct}/${total}`;
  document.getElementById('result-label').textContent = `คะแนน ${pct}%`;

  let msg = '';
  if (pct === 100) msg = '🏆 เยี่ยมมาก! ได้เต็ม!';
  else if (pct >= 75) msg = '😊 ผ่านแล้ว! ทำได้ดีมาก';
  else if (pct >= 50) msg = '📖 พอผ่าน แต่ควรทบทวนเพิ่ม';
  else msg = '📚 ต้องทบทวนอีกนะ มาลองใหม่!';
  document.getElementById('result-msg').textContent = msg;

  // Save score
  if (currentUnit !== 'all') {
    scores[currentUnit] = { score: correct, total };
    saveScores();
  }

  // Review list
  const list = document.getElementById('review-list');
  list.innerHTML = '';
  currentQuestions.forEach((q, i) => {
    const isC = answers[i] === q.ans;
    const li = document.createElement('li');
    li.className = 'review-item ' + (isC ? 'correct-item' : 'wrong-item');
    const letters = ['A','B','C','D'];
    li.innerHTML = `
      <div class="review-q">${i+1}. ${q.q}</div>
      <div class="review-ans">
        ${isC
          ? `<span class="correct-ans">✅ ${letters[q.ans]}. ${q.opts[q.ans]}</span>`
          : `<span class="wrong-ans">❌ คุณตอบ: ${answers[i]!==null?letters[answers[i]]+'. '+q.opts[answers[i]]:'(ไม่ได้ตอบ)'}</span>
             <span class="correct-ans"> | เฉลย: ${letters[q.ans]}. ${q.opts[q.ans]}</span>`}
      </div>
      <div class="trick-exp" style="margin-top:6px;font-size:0.85rem;color:#4b5563;background:#f9fafb;border-radius:8px;padding:8px 12px;line-height:1.6">💡 ${q.exp}</div>`;
    list.appendChild(li);
  });

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function retryQuiz() { startQuiz(currentUnit); }
function goMenu() {
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'none';
  document.getElementById('menu-screen').style.display = 'block';
  renderMenu();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
function goBack() {
  goMenu();
}

// Init
initScores();
renderMenu();
</script>
